{
  "name": "saju",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "pnpm --filter web lint"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
